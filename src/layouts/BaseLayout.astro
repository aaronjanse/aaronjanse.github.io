---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Aaron Janse' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="shortcut icon" type="image/png" href="/favicon.png" />

    <meta property="og:title" content="Aaron Janse" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/asciidots/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:ital,wght@0,200..900;1,200..900&family=Ubuntu+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <div>
        <div id="icon-area">
          <span id="icon-edit">Edit below</span>
          <div id="icon" contenteditable="true" set:html={`
 /<span class="i-dot">.</span>*<span class="i-setter">$#</span>-\\
 \\<span class="i-brace">{</span><span class="i-oper">+</span><span class="i-brace">}</span><span class="i-value">1</span><span class="i-setter">#</span>/

`} />
          <a id="icon-run" href="https://ajanse.me/asciidots/#code:CqAvLiokIy1coAqgXHsrfTEjL6AKCg==" target="_blank">Run online</a>
          <script is:inline>
            (() => {
              const icon = document.querySelector('#icon');
              const iconRun = document.querySelector('#icon-run');
              if (!icon || !iconRun) return;
              icon.addEventListener('input', () => {
                const code = icon.innerText;
                const encoded = btoa(code).replace(/\//g, '_').replace(/\+/g, '-');
                iconRun.href = 'https://ajanse.me/asciidots/?code=' + encoded;
              });
            })();
          </script>
        </div>
        <h1>
          <a href="/">Aaron Janse</a>
        </h1>
      </div>
      <div id="links">
        <a href="https://github.com/aaronjanse">github</a>
        <a href="https://linkedin.com/in/aaronjanse">linkedin</a>
        <a href="#" id="ebg13-link">ebg13</a>
      </div>
      <p>I'm <span id="recent-cal-grad">a recent Cal graduate</span> interested in high&#8209;performance systems and finance.</p>
      <script is:inline>
        if ((new Date()).getFullYear() >= 2028) {
          const el = document.querySelector('#recent-cal-grad');
          if (el) el.remove();
        }
      </script>
    </header>
    <section>
      <slot />
    </section>

